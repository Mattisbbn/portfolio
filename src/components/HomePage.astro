---
import HeroButton from "./HeroButton.astro";
import ExperienceContainer from "./ExperienceContainer.vue";
import SkillPills from "./SkillPills.astro";
import { Icon } from "astro-icon/components";

const usingLanguages = [
  { label: "PHP", icon: "devicon:php", color: "#777BB4" },
  { label: "JavaScript", icon: "devicon:javascript", color: "#F7DF1E" },
  { label: "SQL", icon: "devicon:azuresqldatabase", color: "#4479A1" },
];

const usingFrameworks = [
  { label: "Symfony", icon: "devicon:symfony", color: "#000000" },
  { label: "Laravel", icon: "devicon:laravel", color: "#FF2D20" },
  { label: "React", icon: "devicon:react", color: "#61DAFB" },
  { label: "Vue.js", icon: "devicon:vuejs", color: "#42B883" },
  { label: "Quasar", icon: "devicon:quasar", color: "#16B7FB" },
  { label: "Astro", icon: "devicon:astro", color: "#FF5D01" },
  { label: "TailwindCSS", icon: "devicon:tailwindcss", color: "#38BDF8" },
];

const usingOthers = [
  { label: "Debian", icon: "devicon:debian", color: "#A81D33" },
  { label: "Nginx", icon: "devicon:nginx", color: "#269539" },
  { label: "GitHub", icon: "devicon:github", color: "#181717" },
  { label: "Git", icon: "devicon:git", color: "#F34F29" },
  { label: "Docker", icon: "devicon:docker", color: "#2496ED" },
];

const learning = [
  { label: "Flutter", icon: "devicon:flutter", color: "#47C5FB" },
  { label: "Java", icon: "devicon:java", color: "#EA2D2E" },
];
---

<main>
  <section id="hero" class="h-screen flex items-center justify-center flex-col">
    <h1 class="text-5xl sm:text-7xl font-bold text-bright-gray-900 text-center">
      Mattis Babin
    </h1>
    <h2
      class="text-2xl sm:text-3xl md:text-3xl font-bold text-bright-gray-900 text-center"
    >
      Concepteur développeur
    </h2>

    <div class="flex mt-4 gap-4">
      <HeroButton href="https://github.com/Mattisbbn" name="GitHub">
        <Icon
          slot="icon"
          name="mdi:github"
          class="text-4xl text-bright-gray-900"
        />
      </HeroButton>

      <HeroButton href="https://www.linkedin.com/in/mattisbbn/" name="LinkedIn">
        <Icon
          slot="icon"
          name="mdi:linkedin"
          class="text-4xl text-bright-gray-900"
        />
      </HeroButton>
    </div>
  </section>

  <section
    id="about"
    class="h-screen flex items-center justify-center flex-col"
  >
    <h3 class="text-4xl sm:text-5xl font-bold text-bright-gray-900 text-center">
      Qui suis-je ?
    </h3>

    <p
      class="grid-white-trigger max-w-3xl sm:text-2xl text-xl px-6 whitespace-pre-line text-bright-gray-900 rounded-lg mt-6"
    >
      J'ai 20 ans et je suis passionné par la programmation et l'informatique en général. Après l'obtention de mon BTS SIO, j'ai intégré un Bachelor Concepteur Développeur d'Applications que je réalise actuellement en alternance au sein de la CAF d'Ille-et-Vilaine.
      
      Pour la suite de mon parcours, je suis à la recherche d'une nouvelle alternance de 2 ans pour préparer mon MBA Développeur Full Stack à MyDigitalSchool. 
      
      Curieux et touche-à-tout, je suis capable de gérer la création d'une application de A à Z : de la compréhension du besoin à la réalisation des schémas, en passant par la conception technique et jusqu'au déploiement final.
    </p>
  </section>

  <section
    id="experience"
    class="h-screen flex items-center justify-center flex-col"
  >
    <h3 class="text-4xl sm:text-5xl font-bold text-bright-gray-900 text-center">
      Mon parcours
    </h3>

    <ExperienceContainer class="mt-6" client:idle />
  </section>

  <section
    id="skills"
    class="h-screen flex items-center justify-center flex-col"
  >
    <h3 class="text-4xl sm:text-5xl font-bold text-bright-gray-900 text-center">
      Mes compétences
    </h3>

    <div class="mt-8 flex flex-col gap-4">
      <h4 class="text-3xl font-bold text-gray-800 underline mb-4 ">
        J'utilise :
      </h4>

      <h5 class="text-2xl font-bold text-gray-800 ">Langages</h5>
      <div class="flex flex-row flex-wrap gap-4">
        {
          usingLanguages.map((skill) => (
            <SkillPills label={skill.label} icon={skill.icon} color={skill.color} />
          ))
        }
      </div>

      <h5 class="text-2xl font-bold text-gray-800 ">Frameworks</h5>
      <div class="flex flex-row flex-wrap gap-4">
        {
          usingFrameworks.map((skill) => (
            <SkillPills label={skill.label} icon={skill.icon} color={skill.color} />
          ))
        }
      </div>

      <h5 class="text-2xl font-bold text-gray-800 ">Autres</h5>
      <div class="flex flex-row flex-wrap gap-4">
        {
          usingOthers.map((skill) => (
            <SkillPills label={skill.label} icon={skill.icon} color={skill.color} />
          ))
        }
      </div>

      <h5 class="text-3xl font-bold text-gray-800 underline my-4 ">
        J'apprends :
      </h5>
      <div class="flex flex-row flex-wrap gap-4">
        {
          learning.map((skill) => (
            <SkillPills label={skill.label} icon={skill.icon} color={skill.color} />
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="projects"
    class="h-screen flex items-center justify-center flex-col"
  >
    <h3 class="text-4xl sm:text-5xl font-bold text-bright-gray-900 text-center">
      Mes projets
    </h3>
  </section>


</main>
