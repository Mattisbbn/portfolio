---
import { Icon } from "astro-icon/components";

interface Props {
	label: string;
	icon: string;
	color: string;
}

const { label, icon, color } = Astro.props as Props;
const borderStyle = `border-color: ${color};`;
const iconStyle = `color: ${color};`;
---

<div
	class="flex flex-row gap-2 items-center rounded-full shadow-xl p-1 px-4 backdrop-blur-xs border"
	style={borderStyle}
>
	<Icon name={icon} class="text-xl" style={iconStyle} />
	<p class="text-xl">{label}</p>
</div>